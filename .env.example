# MongoDB local (ajusta usuario/puerto si aplica)
MONGODB_URI=mongodb://127.0.0.1:27017/localizados_venezuela

# URL pública del sitio (metadata, sitemap, enlaces al compartir)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Carpeta de uploads en desarrollo
UPLOAD_DIR=./public/uploads

# reCAPTCHA v3 (formulario /contribuir)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LdGKTYtAAAAAMYmSkp2uNbq0VrPCoMJQgJUwWw9
RECAPTCHA_SECRET=

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-GNN3P1WQW4

# Panel de moderación (/admin) — generar con: npm run admin:secret
# Varias claves separadas por coma = varios moderadores
ADMIN_SECRET=

# OCR de imágenes en el panel (OpenAI Vision)
OPENAI_API_KEY=
# OPENAI_OCR_MODEL=gpt-4o-mini

# Integración con el sitio de desaparecidos (webhook saliente, opcional).
# Si se configura la URL, al publicar un Localizado se hace POST con sus datos
# (ya públicos) para que el otro registro marque su reporte como encontrado.
# Sin URL, es no-op. El SECRET firma el cuerpo con HMAC-SHA256 (cabecera
# X-LV-Signature) para que el socio verifique autenticidad.
DESAPARECIDOS_WEBHOOK_URL=
DESAPARECIDOS_WEBHOOK_SECRET=