# MongoDB local (ajusta usuario/puerto si aplica)
MONGODB_URI=mongodb://127.0.0.1:27017/localizados_venezuela

# URL pública del sitio (metadata, sitemap, enlaces al compartir)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Carpeta de uploads en desarrollo
UPLOAD_DIR=./public/uploads

# reCAPTCHA v3 (formulario /contribuir)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LdGKTYtAAAAAMYmSkp2uNbq0VrPCoMJQgJUwWw9
RECAPTCHA_SECRET=

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-GNN3P1WQW4

# Panel de moderación (/admin) — generar con: npm run admin:secret
# Varias claves separadas por coma = varios moderadores
ADMIN_SECRET=

# OCR de imágenes en el panel (OpenAI Vision)
OPENAI_API_KEY=
# OPENAI_OCR_MODEL=gpt-4o-mini

# Notificaciones web push (PWA) — generar con: npm run webpush:keys
# Canal gratuito: no requiere ningún servicio de correo ni proveedor externo.
# Si hay claves VAPID, los avisos se envían de verdad; sin ellas, solo se registran
# en consola (modo desarrollo).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Mismo valor que VAPID_PUBLIC_KEY, expuesto al cliente para suscribir el navegador.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Contacto requerido por el protocolo webpush (mailto: o https:)
VAPID_SUBJECT=mailto:soporte@localizadosvenezuela.com

# Orígenes extra permitidos en `next dev` (túnel ngrok/cloudflare para probar push
# en el móvil). Hosts sin esquema, separados por coma. Solo afecta a desarrollo.
# DEV_ALLOWED_ORIGINS=xxxx.ngrok-free.app,192.168.0.10